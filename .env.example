# Django
DJANGO_SETTINGS_MODULE=msraa.settings.development
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DEBUG=True

# Database (Docker local)
DATABASE_URL=postgres://postgres:postgres@db:5432/msraa
POSTGRES_DB=msraa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Allowed hosts (comma-separated for production)
ALLOWED_HOSTS=localhost,127.0.0.1

# Cloudinary (required for production media uploads)
# Get from https://cloudinary.com — free tier has 10GB storage, 25GB bandwidth
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Superadmin credentials (used by seed_initial_data command)
SUPERADMIN1_EMAIL=admin1@msraa.cl
SUPERADMIN1_PASSWORD=change-me-strong-password
SUPERADMIN2_EMAIL=admin2@msraa.cl
SUPERADMIN2_PASSWORD=change-me-strong-password

# Email (optional, for contact form)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@msraa.cl
